# Dify App API key — server-side only, never exposed to the browser (required)
APP_KEY=

# Dify API base URL — server-side only (required)
# e.g. https://api.dify.ai/v1  or  your self-hosted endpoint
API_URL=

# Optional: skip runtime app-type detection and use this value directly.
# Valid values: chat | agent | workflow | completion
# Leave blank (default) to auto-detect via /api/parameters + /api/meta.
NEXT_PUBLIC_APP_TYPE=
